// ============================================================================
// Global scope
// ============================================================================

// --- global_scope.h

class C {};
C global;
C* _Nonnull global_ptr = &global;
C& global_ref = global;


// --- import_global_scope.carbon

library "[[@TEST_NAME]]";

import Cpp library "global_scope.h";

fn MyF() {
  let unused local: Cpp.C = Cpp.global;
  let unused local_ptr: Cpp.C* = Cpp.global_ptr;
  let unused local_ref: Cpp.C* = Cpp.global_ref;
}

// ============================================================================
// Unsupported global type
// ============================================================================

// --- unsupported_type.h

using UnusupportedType = _BitInt(23);
UnusupportedType global;

// --- fail_import_unsupported_type.carbon

